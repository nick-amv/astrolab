# Astrolab backend config. Copy to /etc/astrolab/env on the server (never commit
# a real .env). All keys are prefixed ASTROLAB_.

# Core
ASTROLAB_ENVIRONMENT=prod
ASTROLAB_DATABASE_URL=postgresql+psycopg://astrolab:CHANGolytebME@localhost:5432/astrolab
ASTROLAB_CORS_ORIGINS=https://astrolab.nikam.dev

# Privacy / retention
ASTROLAB_RETENTION_DAYS=90
ASTROLAB_REPORT_TTL_DAYS=180

# LLM (dormant until Wave 3). Backend: max_cli | openrouter | disabled
ASTROLAB_LLM_BACKEND=max_cli
ASTROLAB_LLM_TIMEOUT_S=30
ASTROLAB_LLM_RATE_LIMIT_PER_MIN=30
ASTROLAB_LLM_MAX_CONCURRENCY=4
# max_cli backend (Claude via CLI)
ASTROLAB_CLAUDE_CLI_BIN=
ASTROLAB_CLAUDE_CODE_OAUTH_TOKEN=
# openrouter backend (paid fallback)
ASTROLAB_OPENROUTER_API_KEY=
ASTROLAB_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
ASTROLAB_OPENROUTER_MODEL=openai/gpt-4o-mini

# Admin (Wave 5+): comma-separated Telegram ids
ASTROLAB_ADMIN_TG_IDS=
