# Astrolab frontend (SvelteKit adapter-node). Runtime env for the node server.
# adapter-node needs ORIGIN set for CSRF/redirects behind the reverse proxy.
PORT=8016
ORIGIN=https://astrolab.nikam.dev
# Public base for the API (browser + SSR fetch). Same host, /api prefix.
PUBLIC_API_BASE=https://astrolab.nikam.dev/api
