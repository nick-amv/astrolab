{
  "name": "astrolab-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "node build/index.js",
    "check": "npm run compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "test": "npm run compile && vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@inlang/paraglide-js": "^2.0.0",
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8"
  }
}
